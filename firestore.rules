rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required) - User's full name
    //   - birthday: string (optional) - User's birthday
    //   - plan: string (required) - Subscription plan (free, standard, customizable, extended)
    //   - credits: number (required) - Remaining credits
    //   - role: string (required) - User role (user, admin)
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - title: string (required) - Chat title
    //   - createdAt: timestamp (required) - Creation time
    //   - updatedAt: timestamp (required) - Update time
    //
    // Collection: messages
    // Document ID: {messageId}
    // Fields:
    //   - chatId: string (required) - Parent chat ID
    //   - userId: string (required) - Sender UID
    //   - role: string (required) - Sender role (user, assistant)
    //   - content: string (required) - Message content
    //   - type: string (required) - Message type (text, image)
    //   - timestamp: timestamp (required) - Message time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "topupstar71@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'plan', 'credits', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 100 &&
             data.plan in ['free', 'standard', 'customizable', 'extended'] &&
             data.credits is number &&
             data.role in ['user', 'admin'];
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'userId', 'role', 'content', 'type', 'timestamp']) &&
             data.chatId is string &&
             data.userId is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() < 10000 &&
             data.type in ['text', 'image'] &&
             data.timestamp is timestamp;
    }

    function isValidPaymentRequest(data) {
      return data.keys().hasAll(['userId', 'userName', 'userEmail', 'planId', 'planName', 'price', 'method', 'transactionId', 'status', 'createdAt']) &&
             data.userId is string &&
             data.userName is string &&
             data.userEmail is string &&
             data.planId is number &&
             data.planName is string &&
             data.price is number &&
             data.method is string &&
             data.transactionId is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // PII Protection: Only owner or admin can read/write
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidChat(request.resource.data) && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidMessage(request.resource.data) && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /payment_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPaymentRequest(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /credit_logs/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if resource.data.isPublic == true || (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /user_stats/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
